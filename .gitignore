# ==============================================================================
# Music Genre Classification - .gitignore
# ==============================================================================

# Data directories (large files, not tracked in VCS)
data/raw/
data/processed/

# Model outputs (large binary files)
outputs/checkpoints/
outputs/plots/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.env
.venv
env/
venv/
ENV/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
MANIFEST

# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs and temporary files
*.log
*.tmp
*.bak

# Frontend dependencies and cache
frontend/node_modules/
node_modules/
.vite/
